<% if @scores.empty? %>
  <div class="notification_empty">
    <p>単語テストの記録はありません</p>
    <i class="fa-regular fa-bell-slash"></i>
  </div>
<% else %>
  <div class="vocabulary-tests-table-wrapper">
    <table class="vocabulary-tests-table">
      <thead>
        <tr>
          <th>日付</th>
          <th>宿題</th>
          <th>単語テスト</th>
          <th>文テスト</th>
          <th>操作</th>
        </tr>
      </thead>
      <tbody>
        <% @scores.each do |score| %>
          <tr>
            <td><%= score.test_date&.strftime("%Y/%m/%d") %></td>
            <td><%= score.homework&.title %></td>
            <td><%= score.vocabulary_score %> / 10</td>
            <td><%= score.sentence_score %> / 2</td>
            <td>
              <div class="action-menu">
                <%= link_to edit_vocabulary_test_path(score), class:"edit-btn" do %>
                  <i class="fa-solid fa-pen-to-square"></i>
                <% end %>
                <%= link_to vocabulary_test_path(score), class: "delete-btn", data: { turbo_method: :delete, turbo_confirm: "削除しますか？" } do %>
                  <i class="fa-solid fa-trash-can"></i>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>