<div class="score-tracker">
  <header class="tracker-header">
    <p class="tracker-lang">英単語</p>
    <h1>単語テスト記録修正</h1>
  </header>
</div>

<div class="vocabulary-tests-container">
  <div class="vocabulary-tests-form-wrapper">
    <%= form_with model: @score, data: { turbo: false } do |f| %>
    <%= render 'shared/error_message', object: f.object %>
      <div class="form-row">

        <div class="form-group">
          <%= f.label :test_date, "日付" %>
          <%= f.date_field :test_date %>
        </div>

        <div class="form-group">
          <%= f.label :homework_id, "宿題" %>
          <%= f.collection_select :homework_id, @homeworks, :id, :title,
                { prompt: "宿題を選んでください" } %>
        </div>

        <div class="form-group">
          <%= f.label :vocabulary_score, "単語テスト" %>
          <%= f.number_field :vocabulary_score, min: 0, max: 10, placeholder: "例: 8" %>
        </div>

        <div class="form-group">
          <%= f.label :sentence_score, "文テスト" %>
          <%= f.number_field :sentence_score, min: 0, max: 2, placeholder: "例: 2" %>
        </div>

        <div class="form-group align-bottom">
          <%= f.submit "更新する", class: "new-record-btn" %>
        </div>
      </div>

      <% if @score.errors.any? %>
        <ul class="error-list">
          <% @score.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      <% end %>
    <% end %>
  </div>
  <%= link_to "< 戻る", vocabulary_tests_path, class: "back-link" %>
</div>
<%= render "shared/navigation_bar" %>