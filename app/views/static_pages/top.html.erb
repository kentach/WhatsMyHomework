<section class="lp-page-container">
  <div class="logo-header">
    <div class="logo">
      <%= image_tag "/logo.png", alt: "What's My Homework?", width: "50px", height: "50px" %>
      <h1>What's My Homework?</h1>
    </div>
    <i class="fa-solid fa-list-ul"></i>
  </div>

  <nav class="hamburger-menu" id="hamburger-menu">
      <ul>
        <li class="nav-item">
        <i class="fa-solid fa-user-plus"></i>
          <%= link_to new_user_registration_path,
              class: "nav-link" do %>
            新規登録
          <% end %>
        </li>
        
        <li class="nav-item">
        <i class="fa-solid fa-right-to-bracket"></i>
          <%= link_to new_user_session_path,
              class: "nav-link" do %>
            ログイン
          <% end %>
        </li>
      </ul>
  </nav>
  <!-- overlay-->
  <div id="menu-overlay" class="menu-overlay"></div>

  <div class="sub-title-container">
    <h1>宿題がわかる<br>って最高じゃん？</h1>
    <div class="login-btn">
      <div class="cta-section-buttons fade-up delay-1 mt-5">
        <%= link_to "今すぐ始める",
          new_user_registration_path,
          class: "btn btn-lg btn-cta-primary rounded-pill fw-bold shadow" %>

        <%= link_to "ログインする",
          new_user_session_path,
          class: "btn btn-lg btn-cta-outline rounded-pill fw-bold" %>
      </div>
    </div>
  </div>
</section>

<section class="feature-one-title-section">
    <div class="feature-one-title-container">
      <div class="feature-header fade-up">
        <p class="feature-number">
          FEATURE <span>01</span>
        </p>
      </div>

      <div class="feature-heading-group">
        <h2 class="feature-title fade-up delay-1">
          やるべき宿題が<br>すぐ分かる
        </h2>
      </div>

      <div class="feature-description fade-up delay-3">
        <p class="feature-subtitle">
          欠席した時・振替授業でも安心して宿題ができます。
        </p>
      </div>
    </div>
</section>

<div class="feature-two-section">
  <section class="feature-two-title-section">
    <div class="feature-two-title-container">
        <div class="feature-header fade-up">
          <p class="feature-number">
            FEATURE <span>02</span>
          </p>
        </div>

        <div class="feature-heading-group">
          <h2 class="feature-title fade-up delay-1">
            自分の宿題は<br>自分で管理
          </h2>
        </div>

        <div class="feature-description fade-up delay-3">
          <p class="feature-subtitle">
            宿題が終わったら<br>自分で完了チェック✅
          </p>
        </div>
      </div>
  </section>
</div>

<div class="feature-three-section">
  <section class="feature-one-title-section">
    <div class="feature-one-title-container">
        <div class="feature-header fade-up">
          <p class="feature-number">
            FEATURE <span>03</span>
          </p>
        </div>

        <div class="feature-heading-group">
          <h2 class="feature-title fade-up delay-1">
            単語テストを<br>見える化
          </h2>
        </div>

        <div class="feature-description fade-up delay-3">
          <p class="feature-subtitle">
            普段の単語テストの点数を記録して<br>
            学習を可視化しよう。
          </p>
        </div>
      </div>
  </section>
</div>

<div class="feature-two-section">
  <section class="feature-two-title-section">
    <div class="feature-two-title-container">
        <div class="feature-header fade-up">
          <p class="feature-number">
            FEATURE <span>04</span>
          </p>
        </div>

        <div class="feature-heading-group">
          <h2 class="feature-title fade-up delay-1">
            先生からの通知が<br>すぐ届く
          </h2>
        </div>

        <div class="feature-description fade-up delay-3">
          <p class="feature-subtitle">
            計画的に月例単語テストの<br>
            学習ができます。
          </p>
        </div>
      </div>
  </section>
</div>

<section class="sign-up-btn-container">
  <div class="sign-up-section">
      <h1>効率よく宿題できたら、最高じゃん？</h1>
      <p>宿題管理、始めませんか？</p>
      <div class="cta-section-buttons mt-5">
        <%= link_to "今すぐ始める",
          new_user_registration_path,
          class: "btn btn-lg btn-cta-primary rounded-pill fw-bold shadow" %>
      </div>
  </div>
</section>

<%= render "shared/footer" %>
