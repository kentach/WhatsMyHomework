<div class="row">
  <div class="col-12">
    <div class="card">
      <div class="card-header">
        <h3 class="card-title">クラス編集</h3>
      </div>
      <div class="card-body">
        <%= form_with model: [:admin, @classroom] do |f| %>
          <% if @classroom.errors.any? %>
            <div class="alert alert-danger">
              <% @classroom.errors.full_messages.each do |msg| %>
                <p><%= msg %></p>
              <% end %>
            </div>
          <% end %>

          <div class="mb-3">
            <%= f.label :name, "クラス名", class: "form-label" %>
            <%= f.text_field :name, autofocus: true, placeholder: "クラス名", class: "form-control" %>
          </div>

          <div class="mb-3">
            <%= f.label :eiken_level, "クラス名(英語表記)", class: "form-label" %>
            <%= f.text_field :eiken_level, autofocus: true, placeholder: "クラス名", class: "form-control" %>
          </div>
      
          <div class="d-flex gap-2">
            <%= f.submit "更新する", class: "btn btn-primary" %>
            <%= link_to "キャンセル", admin_classrooms_path, class: "btn btn-secondary" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>