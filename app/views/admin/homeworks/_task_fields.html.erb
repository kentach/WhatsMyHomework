<div class="task-fields border rounded p-3 mb-2">
  <%= f.hidden_field :id %>
  <div class="mb-2">
    <%= f.label :name, "宿題の詳細", class: "form-label" %>
    <%= f.text_field :name, class: "form-control" %>
  </div>
  <div class="mb-2">
    <%= f.label :pdf, "PDF", class: "form-label" %>
    <% if f.object.pdf.attached? %>
      <div class="mb-1">
        <i class="fas fa-file-pdf text-danger"></i>
        <%= link_to f.object.pdf.filename, url_for(f.object.pdf), target: "_blank", class: "text-decoration-none" %>
      </div>
    <% end %>
    <%= f.file_field :pdf, class: "form-control", accept: "application/pdf" %>
  </div>
  <%= f.hidden_field :_destroy, class: "destroy-flag" %>
  <button type="button" class="btn btn-outline-danger btn-sm remove-task">削除</button>
</div>