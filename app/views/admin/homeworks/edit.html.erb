<div class="row">
  <div class="col-12">
    <div class="card">
      <div class="card-header">
        <h3 class="card-title">宿題編集</h3>
      </div>
      <div class="card-body">
        <%= form_with model: [:admin, @homework] do |f| %>
          <% if @homework.errors.any? %>
            <div class="alert alert-danger">
              <% @homework.errors.full_messages.each do |msg| %>
                <p><%= msg %></p>
              <% end %>
            </div>
          <% end %>

          <div class="mb-3">
            <%= f.label :title, "タイトル", class: "form-label" %>
            <%= f.text_field :title, autofocus: true, placeholder: "クラス名 Week◯◯", class: "form-control" %>
          </div>

          <div class="mb-3">
            <%= f.label :classroom_id, "クラス", class: "form-label" %>
            <%= f.collection_select :classroom_id, Classroom.all, :id, :name, { prompt: "クラスを選択" }, class: "form-select" %>
          </div>

          <div class="mb-3">
            <label class="form-label fw-bold">内容</label>
            <div id="tasks">
              <%= f.fields_for :tasks do |task_form| %>
                <%= render "task_fields", f: task_form %>
              <% end %>
            </div>
            <button type="button" class="btn btn-outline-secondary btn-sm mt-2" id="add-task">
              + タスクを追加
            </button>
          </div>

          <div class="mb-3">
            <%= f.label :status, "ステータス", class: "form-label" %>
            <%= f.select :status, [["下書き", "draft"], ["公開", "published"]], {}, class: "form-select" %>
          </div>

          <div class="mb-3">
            <%= f.label :test_start_date, "テスト開始日", class: "form-label" %>
            <%= f.datetime_local_field :test_start_date, class: "form-control" %>
          </div>

          <div class="mb-3">
            <%= f.label :test_end_date, "テスト終了日", class: "form-label" %>
            <%= f.datetime_local_field :test_end_date, class: "form-control" %>
          </div>

          <div class="d-flex gap-2">
            <%= f.submit "更新する", class: "btn btn-primary" %>
            <%= link_to "キャンセル", admin_homeworks_path, class: "btn btn-secondary" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>