<div class="row">
  <div class="col-12">
    <div class="card">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h3 class="card-title">宿題一覧</h3>
        <%= link_to "新規作成", new_admin_homework_path, class: "btn btn-primary btn-sm" %>
      </div>
      <div class="card-body">
        <table class="table table-bordered table-hover">
          <thead>
            <tr>
              <th>タイトル</th>
              <th>ステータス</th>
              <th>クラス</th>
              <th>テスト開始日</th>
              <th>テスト終了日</th>
              <th>編集</th>
              <th>削除</th>
            </tr>
          </thead>
          <tbody>
            <% @homeworks.each do |homework| %>
              <tr>
                <td><%= homework.title %></td>
                <td><%= homework.status %></td>
                <td><%= homework.classroom&.name %></td>
                <td><%= homework.test_start_date&.strftime("%Y/%m/%d") %></td>
                <td><%= homework.test_end_date&.strftime("%Y/%m/%d") %></td>
                <td>
                  <%= link_to "編集", edit_admin_homework_path(homework), class: "btn btn-sm btn-warning" %>
                </td>
                <td>
                  <%= button_to "削除", admin_homework_path(homework), method: :delete, data: { turbo_confirm: "削除しますか？" }, class: "btn btn-sm btn-danger" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>