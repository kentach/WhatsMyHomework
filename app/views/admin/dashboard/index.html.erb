<div class="row">
  <div class="col-lg-3 col-6">
    <div class="small-box bg-primary">
      <div class="inner">
        <h3><%= @homeworks.count %></h3>
        <p>宿題総数</p>
      </div>
      <%= link_to "一覧を見る", admin_homeworks_path, class: "small-box-footer text-white" %>
    </div>
  </div>

  <div class="col-lg-3 col-6">
    <div class="small-box bg-success">
      <div class="inner">
        <h3><%= @published_homeworks.count %></h3>
        <p>公開中</p>
      </div>
      <%= link_to "一覧を見る", admin_homeworks_path, class: "small-box-footer text-white" %>
    </div>
  </div>

  <div class="col-lg-3 col-6">
    <div class="small-box bg-warning">
      <div class="inner">
        <h3><%= @draft_homeworks.count %></h3>
        <p>下書き</p>
      </div>
      <%= link_to "一覧を見る", admin_homeworks_path, class: "small-box-footer text-white" %>
    </div>
  </div>

  <div class="col-lg-3 col-6">
    <div class="small-box bg-info">
      <div class="inner">
        <h3><%= @classrooms.count %></h3>
        <p>クラス数</p>
      </div>
      <%= link_to "クラス一覧", admin_classrooms_path, class: "small-box-footer text-white" %>
    </div>
  </div>
</div>

<div class="row">
  <div class="col-12">
    <div class="card">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h3 class="card-title">最近の宿題</h3>
        <%= link_to "新規作成", new_admin_homework_path, class: "btn btn-primary btn-sm" %>
      </div>
      <div class="card-body p-0">
        <table class="table table-hover mb-0">
          <thead>
            <tr>
              <th>タイトル</th>
              <th>ステータス</th>
              <th>クラス</th>
              <th>テスト開始日</th>
              <th>操作</th>
            </tr>
          </thead>
          <tbody>
            <% @recent_homeworks.each do |homework| %>
              <tr>
                <td><%= homework.title %></td>
                <td>
                  <% if homework.status == "published" %>
                    <span class="badge bg-success">公開中</span>
                  <% else %>
                    <span class="badge bg-warning">下書き</span>
                  <% end %>
                </td>
                <td><%= homework.classroom&.name %></td>
                <td><%= homework.test_start_date&.strftime("%Y/%m/%d") %></td>
                <td>
                  <%= link_to "編集", edit_admin_homework_path(homework), class: "btn btn-sm btn-warning" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>