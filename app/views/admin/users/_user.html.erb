<tr>
  <td><%= user.id %></td>
  <td><%= user.name %></td>
  <td><%= user.student_id %></td>
  <td>
    <% if user.admin? %>
      <span class="badge bg-danger">管理者</span>
    <% else %>
      <span class="badge bg-primary">生徒</span>
    <% end %>
  </td>
  <td><%= user.classroom&.eiken_level %></td>
  <td><%= user.created_at.strftime("%Y/%m/%d") %></td>
  <td class="d-flex gap-1 align-items-center">
  <%= link_to "編集", edit_admin_user_path(user), class: "btn btn-sm btn-warning" %>
  <%= button_to "削除", admin_user_path(user),
        method: :delete,
        data: { turbo_confirm: "削除しますか？" },
        form_class: "d-inline",
        class: "btn btn-sm btn-danger" %>
</td>
</tr>