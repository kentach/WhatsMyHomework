<div class="container">
  <div class="login-card">

    <h2 class="login-title">ログイン</h2>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>

      <div class="form-group">
        <%= f.label :email, "メール", class: "form-label" %>
        <%= f.email_field :email, class: "form-label" %>
      </div>

      <div class="form-group">
        <%= f.label :password, "パスワード", class: "form-label" %>
        <%= f.password_field :password, class: "form-label" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="form-check">
          <%= f.check_box :remember_me, class: "form-check-input" %>
          <%= f.label :remember_me, "ログイン状態を保持する", class: "form-check-label" %>
        </div>
      <% end %>

      <%= f.submit "ログイン", class: "signup-btn" %>

    <% end %>

    <div class="auth-links">
      <%= render "devise/shared/links" %>
    </div>

  </div>
</div>